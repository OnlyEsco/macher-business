# Discord OAuth2 - https://discord.com/developers/applications
DISCORD_CLIENT_ID=DEINE_CLIENT_ID
DISCORD_CLIENT_SECRET=DEIN_CLIENT_SECRET
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Turso Datenbank - https://turso.tech
TURSO_DATABASE_URL=libsql://DEINE-DB.turso.io
TURSO_AUTH_TOKEN=DEIN_TURSO_TOKEN

# Session Secret - Zufälliger langer String
SESSION_SECRET=aendern_zu_einem_langen_zufaelligen_string_123456789

# Deine Discord User ID (für Super-Admin)
# Finde sie: Discord -> Einstellungen -> Erweitert -> Entwicklermodus -> Rechtsklick auf dich selbst -> ID kopieren
SUPER_ADMIN_DISCORD_ID=DEINE_DISCORD_USER_ID

# Port
PORT=3000
